# Server-only upstream configuration. Preview deployments should target the
# isolated Preview API and keep its Vercel bypass token server-side.
GRIDSYNAPSE_API_ORIGIN=http://127.0.0.1:8080
GRIDSYNAPSE_API_BYPASS_SECRET=

# Server-only key shared with the API. The browser always calls /api/proxy and never receives it.
GRIDSYNAPSE_API_WRITE_KEY=
