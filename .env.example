GRIDSYNAPSE_LIVE_MARKET_ENABLED=true
GRIDSYNAPSE_LIVE_MARKET_CACHE_SECONDS=1800

# Portfolio-safe procurement planning is on. Billable provider execution stays off.
GRIDSYNAPSE_PROCUREMENT_ENABLED=true
GRIDSYNAPSE_EXECUTION_ENABLED=false

# Backend-only durable decision storage. Never expose either server key to the web app.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Alternative when a Supabase secret key is unavailable. The publishable key identifies
# the project; the GridSynapse database key is checked by RLS and remains server-only.
SUPABASE_PUBLISHABLE_KEY=
GRIDSYNAPSE_DATABASE_API_KEY=
